# =============================
# PHP / MySQL project .gitignore
# =============================

# ---- Environment & secrets ----
.env
.env.local
.env.*.local
.env.production
.env.staging
*.env

# ---- PHP ----
vendor/
composer.lock
composer.phar
.phpunit.result.cache
phpunit.xml
.php-cs-fixer.cache

# ---- Dependencies (if added later) ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Storage & runtime ----
storage/logs/*
!storage/logs/.gitkeep
storage/settings.json
storage/barcode_bridge/*.json
storage/cache/
storage/sessions/
storage/uploads/
*.log

# Keep required storage files
!storage/schema.sql
!storage/patch_sales_table.sql
!storage/.gitkeep

# ---- IDE & editors ----
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# ---- OS ----
.DS_Store
Thumbs.db
Desktop.ini

# ---- Build & deploy ----
dist/
build/
*.tar
*.zip
.deploy/

# ---- Optional: exclude large/sensitive dirs ----
skills/

# ---- Temporary fix/patch scripts (dev only) ----
storage/fix_*.php
storage/fix_*.py
storage/check_*.php
