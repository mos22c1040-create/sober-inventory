# انسخ هذا الملف إلى .env وعدّل القيم
# Copy this file to .env and set your values

# --- خيار 1: MySQL (محلي أو استضافة) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=inventory_pos
DB_USERNAME=root
DB_PASSWORD=

# --- خيار 2: Supabase (PostgreSQL) — استخدم هذا فقط واترك DB_* فارغة ---
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.xxxx.supabase.co:5432/postgres

# Environment (development | production)
APP_ENV=development

# Session storage: file (default) | database (مطلوب لـ Vercel/Serverless)
SESSION_DRIVER=file

# Flutter Web من localhost: ضع 1 + APP_ENV=production حتى تعمل جلسة API بين دومينين (اختياري — يزيد سطح CSRF قليلاً)
# SESSION_CROSS_ORIGIN=1
